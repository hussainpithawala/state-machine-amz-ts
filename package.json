{
  "name": "@hussainpithawala/state-machine-amz-ts",
  "version": "0.0.3",
  "description": "AWS Step Functions compatible embedded workflow engine for TypeScript/Node.js",
  "keywords": [
    "state-machine",
    "workflow",
    "orchestration",
    "amazon-states-language",
    "step-functions",
    "typescript",
    "embedded"
  ],
  "author": "Hussain Pithawala <hussainpithawala@hotmail.com>",
  "license": "MIT",
  "homepage": "https://github.com/hussainpithawala/state-machine-amz-ts",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hussainpithawala/state-machine-amz-ts.git"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsup --clean",
    "build:watch": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "jest --detectOpenHandles",
    "test:unit": "jest --testPathPattern='crc-tlv'",
    "test:coverage": "jest --coverage",
    "lint": "eslint src test --ext .ts --max-warnings 0",
    "lint:fix": "eslint src test --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"test/**/*.ts\"",
    "clean": "rm -rf dist coverage",
    "prepublishOnly": "npm run build",
    "ci": "npm run typecheck && npm run lint && npm run format:check && npm test && npm run build"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@eslint/json": "^1.0.1",
    "@types/jest": "^29.5.12",
    "@types/js-yaml": "^4.0.9",
    "eslint": "^10.0.0",
    "globals": "^17.3.0",
    "jest": "^29.7.0",
    "jiti": "^2.6.1",
    "jsonpath-plus": "10.4.0",
    "prettier": "^3.3.0",
    "ts-jest": "^29.1.5",
    "ts-node": "^10.9.2",
    "tsup": "^8.1.0",
    "typescript": "^5.4.5",
    "typescript-eslint": "^8.56.0"
  },
  "engines": {
    "node": ">=18"
  }
}
